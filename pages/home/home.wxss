page {
  text-align: center;
  box-sizing: border-box;
  padding-bottom: calc(env(safe-area-inset-bottom) + 96rpx);
}

.user {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
}

.user__description {
  color:#aaa;
  padding-top: 40rpx;
  padding-bottom: 40rpx;
}

.user__socials {
  display: flex;
  gap: 30rpx;
  align-items: center;
}

.user__social-text {
  font-size: small;
  color:#aaa;
}

.icon-github:before,
.icon-blog:before {
  content: '\00a0\00a0\00a0';
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

